/*
 * conf/local_refs.config — machine-specific reference paths for THIS deployment.
 * Loaded automatically when --data local (the default).
 *
 * Copy this file to a new installation and update the paths.
 * For a zero-config portable run use --data discanvis_data instead.
 */

// ── Execution (machine-specific) ─────────────────────────────────────────────
workDir = 'work_local'

process {
    withLabel: 'process_low'    { cpus = 2;  memory = '8 GB';   time = '2 h'    }
    withLabel: 'process_medium' { cpus = 6;  memory = '16 GB';  time = '4 h'    }
    withLabel: 'process_high'   { cpus = 8;  memory = '32 GB';  time = '8 h'    }
}

params {
    // ── Reference FASTAs / GTF (local, full proteome) ────────────────────────
    uniprot_fasta         = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/UP000005640_9606.fasta'
    uniprot_isoform_fasta = '/dlab/home/norbi/Bori_DiplomaMunka/external_data/UP000005640_9606_additional.fasta'
    gencode_fasta         = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.pc_translations.fa'
    gencode_gtf           = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.chr_patch_hapl_scaff.annotation.gtf.gz'
    gencode_transcripts   = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.pc_transcripts.fa'
    gencode_refseq        = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.metadata.RefSeq'
    hg38_2bit             = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/hg38/hg38.2bit'

    // ── Disorder / CoiledCoils library paths ─────────────────────────────────
    ext_programs    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Programs'
    aiupred_python  = '/home/nosyfire/miniconda3/envs/finches/bin/python'
    deepcoil_python = '/home/nosyfire/miniconda3/envs/deepcoil_env/bin/python'

    // ── PPI — downloaded + preprocessed by FETCH_INTACT/BIOGRID/HIPPIE + PPI_PREPROCESS ─
    // null → pipeline downloads raw MiTab from EBI/BioGRID/HIPPIE and converts automatically
    // (cached in references/ppi/processed/ via storeDir).
    // Set to a path only to override with a pre-processed file.
    ppi_intact  = null
    ppi_biogrid = null
    ppi_hippie  = null

    // ── Conservation (local pre-computed) ────────────────────────────────────
    gopher_conservation_table = '/dlab/home/norbi/data/Gopher/DisCanVis2/quefo/HUMAN/conservation/conservation_table.tsv'
    phastcons_dir             = '/dlab/home/norbi/data/phastcons'

    // ── Mutations (ClinVar / TCGA / cBioPortal) ──────────────────────────────
    clinvar_vcf    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Automated_Pipeline/data/raw/mutations/clinvar/v_2026_03_09/clinvar.vcf.gz'
    tcga_maf       = '/dlab/home/norbi/PycharmProjects/Cancer_Visualization_Data_Process/32_Genome_version_mapping/data/process_cancerviz_01/TCGA_hg38.maf'
    cbioportal_maf = '/dlab/home/norbi/PycharmProjects/Cancer_Visualization_Data_Process/32_Genome_version_mapping/data/process_cancerviz_01/Cbioportal_hg38.maf'

    // ── Disease ontology ─────────────────────────────────────────────────────
    mondo_obo           = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/disease_ontology/mondo/mondo.obo'
    clinvar_disease_tsv = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/tables/clinvar_table_with_ontology_only_disease_pathogen_annotate.tsv'
    omim_tsv            = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/tables/omim_table_with_ontology_with_annotate.tsv'
    omim_mutations_tsv  = '/dlab/home/norbi/PycharmProjects/Cancer_Visualization_Data_Process/7.2_OMIM_Desease/data/process_gencode/omim_mapped.tsv'

    // ── AlphaMissense / MaveDB / ProteinGym (benchmark + pathogenicity) ──────
    alphamissense_gz = '/dlab/home/norbi/PycharmProjects/AlphaMissense/data/AlphaMissense_isoforms_hg38.tsv.gz'
    mavedb_tsv       = '/dlab/home/norbi/PycharmProjects/Benchmark_Pathogenicity_Predictors/data/mavedb/mave_single_mutant_protein.tsv'
    proteingym_tsv   = '/dlab/home/norbi/PycharmProjects/Benchmark_Pathogenicity_Predictors/data/benchmark/processed_proteingym_results_hg38_mapping_isoforms.tsv'

    // ── DepMap (local pre-processed) ─────────────────────────────────────────
    depmap_tsv = '/dlab/home/norbi/PycharmProjects/Turbine_Projects/variant_driven_cellular_vulnerability/data/raw/depmap/mapped_filtered_mutations.tsv'

    // ── dbNSFP ───────────────────────────────────────────────────────────────
    // Two modes (mutually exclusive — raw takes priority when both are set):
    //
    // 1. Raw chr*.gz → DBNSFP_MAP process maps via combined_map.map (slower, always current)
    //    Raw files: dbNSFP4.8a on this machine at the path below.
    dbnsfp_raw_dir = '/dlab/home/norbi/PycharmProjects/Mapping/pythonProject/External_Data/pathogenicity_predictors/dbNSFP4.8a'
    //
    // 2. Pre-mapped Protein_ID-keyed TSV → PATHOGENICITY_MAP (fast filter, but frozen snapshot)
    //    Uncomment to use the pre-mapped fallback instead:
    // dbnsfp_tsv = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/dbNSFP_custom/mapped_filtered_mutations.tsv'
    dbnsfp_tsv = null

    // ── Polymorphisms (all + allele frequency) ───────────────────────────────
    snp_pos_tsv    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/positional_data_process/polymorphism_pos.tsv'
    snp_out_common = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/SNP/common_poly.out'
    snp_out_all    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/SNP/all_poly.out'
    // Preferred polymorphism source: dbSNP common bigBed — rsid + allele frequency
    // extracted per selected isoform via combined_map (overrides the .out / pos tables).
    dbsnp_bb       = '/home/nosyfire/data/snp/155/dbSnp155Common.bb'
    ucsc_bin       = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Programs/UCSC/UCSC_utils_64'

    // ── Cancer drivers (vendored gene-keyed roles are in legacy_data/) ───────
    // cancer_driver_tsv / census_roles_tsv / compendium_roles_tsv default to
    // the in-repo legacy_data/drivers/ files (see nextflow.config).

    // ── PEM Core Motifs / ScanSite fallback ──────────────────────────────────
    pem_dataset  = '/dlab/home/norbi/paper_projects/IDP_Pathogenic_Mutations/processed_data/files/supplementary/predicted_elm_dataset.tsv'
    scansite_tsv = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/annotations/domains_and_motifs/scansite.tsv'
}

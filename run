#!/usr/bin/env bash
# DisCanVisFlow launcher — clean named-argument interface for Nextflow profiles.
#
# Usage:
#   ./run [--env conda|docker|slurm] [--data local|discanvis_data] [--project <name>]
#         [--description "text"] [any nextflow argument...]
#
# Examples:
#   ./run --data local --target_gene RAF1 -stub
#   ./run --data discanvis_data --project cellular_vulnerability -resume
#   ./run --data discanvis_data --project cellular_vulnerability --env slurm -resume
#   ./run --data discanvis_data --project test_one_protein --target_gene BRCA1 -resume
#   ./run --data discanvis_data --project discanvis --description "Q4 2026 update" -resume
#
# The --env, --data, and --project arguments are translated to -profile <list> internally.
# All other arguments are passed through to `nextflow run main.nf` unchanged.

set -euo pipefail

ENV="conda"
DATA=""
PROJECT=""
DESCRIPTION=""
NF_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --env)         ENV="$2";         shift 2 ;;
        --data)        DATA="$2";        shift 2 ;;
        --project)     PROJECT="$2";     shift 2 ;;
        --description) DESCRIPTION="$2"; shift 2 ;;
        *)             NF_ARGS+=("$1");  shift ;;
    esac
done

# Build comma-separated -profile list: data,project,env (order matters for overrides)
PROFILES=()
[[ -n "$DATA" ]]    && PROFILES+=("$DATA")
[[ -n "$PROJECT" ]] && PROFILES+=("$PROJECT")
[[ -n "$ENV" ]]     && PROFILES+=("$ENV")

CMD=(nextflow run main.nf)
[[ ${#PROFILES[@]} -gt 0 ]] && CMD+=(-profile "$(IFS=,; echo "${PROFILES[*]}")")
[[ -n "$DESCRIPTION" ]]     && CMD+=(--description "$DESCRIPTION")
CMD+=("${NF_ARGS[@]}")

echo ""
echo "  → ${CMD[*]}"
echo ""
exec "${CMD[@]}"

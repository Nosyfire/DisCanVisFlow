/*
 * config/data/discanvis_data.config — zero-config reference data source
 * Loaded when --data discanvis_data (auto-downloads all references).
 * FETCH_* processes cache downloads in references/ via storeDir.
 */

workDir = 'work/discanvis_data'

// When running via `nextflow run Nosyfire/DisCanVisFlow`, projectDir resolves
// to ~/.nextflow/assets/.repos/... (the NF clone cache, typically on a small
// home partition).  launchDir is the directory from which the user ran nextflow
// — usually a large data partition — so pin ref_dir and ext_programs there.
params {
    ref_dir      = "${launchDir}/references"
    ext_programs = "${launchDir}/External_Programs"
    // ── Auto-download all refreshing references ───────────────────────────────
    // Setting a param to null triggers the corresponding FETCH_* process.
    uniprot_fasta         = null
    uniprot_isoform_fasta = null
    gencode_fasta         = null
    gencode_gtf           = null
    gencode_transcripts   = null
    gencode_refseq        = null
    alphamissense_gz      = null
    clinvar_vcf           = null
    mondo_obo             = null
    ppi_intact            = null
    ppi_biogrid           = null
    ppi_hippie            = null

    // Genome + polymorphisms
    hg38_2bit       = null
    fetch_hg38_2bit = true
    dbsnp_bb        = null
    fetch_dbsnp     = true

    // PDB — SIFTS bulk join is faster than per-protein PDBe API calls
    pdb_bulk  = true
    sifts_tsv = null

    // Open datasets — fetch fresh
    mavedb_tsv      = null
    fetch_mavedb    = true
    skip_mavedb     = false
    proteingym_tsv  = null
    fetch_proteingym = true
    skip_proteingym  = false
    // DepMap blocks scripted catalogue downloads behind browser verification on
    // some networks. Keep it as a manual reference by default:
    //   1. Download OmicsSomaticMutations.csv from https://depmap.org/portal/download/all/
    //   2. Save it as references/depmap/OmicsSomaticMutations.csv
    //   3. The pipeline preflight confirms the raw CSV and normalises it if needed.
    depmap_raw_csv  = "${launchDir}/references/depmap/OmicsSomaticMutations.csv"
    depmap_tsv      = "${launchDir}/references/depmap/depmap_mutations_raw.tsv"
    fetch_depmap    = false
    skip_depmap     = false

    // OMIM disease via UniProt humsavar.txt (open, no key required)
    omim_tsv           = null
    omim_mutations_tsv = null
    fetch_omim         = true
    skip_omim          = false

    // Licence-gated tracks off by default; enable by supplying the param/URL
    dbnsfp_tsv       = null
    tcga_maf         = null
    cbioportal_maf   = null
    skip_conservation = true
    skip_pathogenicity = true

    // Disorder: auto-setup clones AIUPred, creates conda envs, installs bigBedToBed
    ext_programs = "${projectDir}/External_Programs"
    auto_setup   = true
}

conda.enabled       = true
conda.createTimeout = '60 min'

// Use the active conda env only when it contains makeblastdb (i.e. the user has
// already activated the discanvis env).  Otherwise let Nextflow build/reuse it
// from environment.yml — this handles fresh machines and GitHub-run invocations
// where the env has not been created yet.
// NOTE: Nextflow config files do not allow `def` declarations; all logic must be
// expressed as inline Groovy within the assignment.
process.conda = System.getenv('CONDA_PREFIX') &&
    new File("${System.getenv('CONDA_PREFIX')}/bin/makeblastdb").exists()
    ? System.getenv('CONDA_PREFIX')
    : "${projectDir}/environment.yml"

// Cache Nextflow-managed conda envs next to the work dir (launchDir), not inside
// the NF clone cache (~/.nextflow/assets/...) which lives on the small home partition.
conda.cacheDir = "${launchDir}/.nextflow-conda-cache"

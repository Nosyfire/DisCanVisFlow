conda.enabled       = true
conda.createTimeout = '60 min'

// Use the active conda env only if it contains the pipeline's core tools (makeblastdb).
// When running via `nextflow run Nosyfire/DisCanVisFlow` without first activating the
// discanvis env, CONDA_PREFIX may point to the base env or be unset — fall back to
// building the env from environment.yml in that case.
def _conda_prefix = System.getenv('CONDA_PREFIX') ?: ''
def _has_tools    = _conda_prefix && new File("${_conda_prefix}/bin/makeblastdb").exists()
process.conda  = _has_tools ? _conda_prefix : "${projectDir}/environment.yml"

// Cache Nextflow-managed conda envs next to the work dir (launchDir), not inside the
// NF clone cache (~/.nextflow/assets/...) which lives on the small home partition.
conda.cacheDir = "${launchDir}/.nextflow-conda-cache"

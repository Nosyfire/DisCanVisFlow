// Small local workstation.
executor {
    name      = 'local'
    cpus      = 4
    memory    = params.ram ?: '8 GB'
    queueSize = 2
}

process {
    maxForks = 2
    withLabel: 'process_low' {
        cpus   = 1
        memory = params.ram ?: '8 GB'
        time   = '4 h'
    }
    withLabel: 'process_medium' {
        cpus   = 2
        memory = params.ram ?: '8 GB'
        time   = '12 h'
    }
    withLabel: 'process_high' {
        cpus   = 2
        memory = params.ram ?: '8 GB'
        time   = '24 h'
    }
}

params {
    scatter_chunks  = 2
    blat_chunks     = 2
    genome_map_cpus = 2
}

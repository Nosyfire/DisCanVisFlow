// 32 GB RAM, 6-core workstation or cluster node.
// BLAT loads hg38.2bit (~4 GB) per process.
// blat_chunks=4 → 4 × 4 GB = 16 GB peak for BLAT, leaving 16 GB headroom.
executor {
    name      = 'local'
    cpus      = 6
    memory    = params.ram ?: '32 GB'
    queueSize = 6
}

process {
    withLabel: 'process_low' {
        cpus   = 1
        memory = params.ram ?: '4 GB'
        time   = '4 h'
    }
    withLabel: 'process_medium' {
        cpus   = 2
        memory = params.ram ?: '16 GB'
        time   = '12 h'
    }
    withLabel: 'process_high' {
        cpus   = 4
        memory = params.ram ?: '28 GB'
        time   = '24 h'
    }
}

params {
    scatter_chunks  = 4
    blat_chunks     = 4
    genome_map_cpus = 4
}

// Large local workstation/server.
executor {
    name      = 'local'
    cpus      = 64
    memory    = params.ram ?: '256 GB'
    queueSize = 24
}

process {
    withLabel: 'process_low' {
        cpus   = 2
        memory = params.ram ?: '8 GB'
        time   = '2 h'
    }
    withLabel: 'process_medium' {
        // Most annotation workers are single-threaded Python; declaring 4 CPUs
        // lets 16 tasks run concurrently (vs 4 with 16 CPUs each on a 64-CPU box).
        cpus   = 4
        memory = params.ram ?: '32 GB'
        time   = '6 h'
    }
    withLabel: 'process_high' {
        cpus   = 24
        memory = params.ram ?: '128 GB'
        time   = '12 h'
    }
    // BLASTP is CPU-bound; 16 CPUs keeps it fast and matches the cached full-proteome runs.
    withName: 'BLASTP' { cpus = 16 }
    // DBNSFP_MAP: 24 chromosome files processed in parallel by multiprocessing.Pool.
    // Each worker reads/parses one chr*.gz and does dict lookups — CPU-bound once in RAM cache.
    // 24 CPUs → all 24 chr files in one pass. Memory-safe: pid_map shared via fork COW.
    withName: 'DBNSFP_MAP' {
        cpus   = 24
        memory = params.ram ?: '128 GB'
    }
    // COILEDCOILS_MAP is I/O-bound and single-threaded.
    withName: 'COILEDCOILS_MAP' {
        cpus   = 4
        memory = params.ram ?: '16 GB'
    }
}

params {
    scatter_chunks  = 20
    // 2 × BLASTP (process_medium = 16 CPUs each) = 32 CPUs. Remaining: 64 − 32 = 32.
    // blat_chunks=32 fills all 32 idle CPUs, cutting BLAT phase from ~40 min to ~20 min.
    blat_chunks     = 32
    genome_map_cpus = 24
}

// 8 GB laptop / WSL-safe mode: one small task at a time.
executor {
    name      = 'local'
    cpus      = 2
    memory    = params.ram ?: '5 GB'
    queueSize = 1
}

process {
    maxForks = 1
    withLabel: 'process_low' {
        cpus   = 1
        memory = params.ram ?: '4 GB'
        time   = '6 h'
    }
    withLabel: 'process_medium' {
        cpus   = 1
        memory = params.ram ?: '4 GB'
        time   = '24 h'
    }
    withLabel: 'process_high' {
        cpus   = 1
        memory = params.ram ?: '4 GB'
        time   = '48 h'
    }
}

params {
    scatter_chunks  = 1
    blat_chunks     = 1
    genome_map_cpus = 1
}

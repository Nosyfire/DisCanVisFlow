// Normal local workstation.
executor {
    name      = 'local'
    cpus      = 16
    memory    = params.ram ?: '64 GB'
    queueSize = 8
}

process {
    withLabel: 'process_low' {
        cpus   = 2
        memory = params.ram ?: '8 GB'
        time   = '2 h'
    }
    withLabel: 'process_medium' {
        cpus   = 6
        memory = params.ram ?: '32 GB'
        time   = '6 h'
    }
    withLabel: 'process_high' {
        cpus   = 8
        memory = params.ram ?: '64 GB'
        time   = '12 h'
    }
}

params {
    scatter_chunks  = 8
    blat_chunks     = 8
    genome_map_cpus = 8
}

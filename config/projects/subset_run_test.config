// --project subset_run_test: small multi-gene subset run (RAF1, CTNNB1, TP53,
// BRAF). Full pipeline (blast + intermediate + final + reports), same mapping
// thresholds as discanvis. Handy end-to-end smoke test that still exercises
// every module on real genes.
params {
    outdir         = 'results/subset_run_test'
    target_gene    = 'RAF1,CTNNB1,TP53,BRAF'
    mapping_mode   = 'all_isoform_mapping'
    blast_coverage = 80
    idmap_coverage = 95
    seq_cutoff     = 80

    blat_chunks    = 1
    scatter_chunks = 1
    per_gene_md_threshold = 50

    fetch_cbioportal = true
}

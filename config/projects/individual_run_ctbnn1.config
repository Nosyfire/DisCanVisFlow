// --project individual_run_ctbnn1: standalone single-gene run for CTNNB1
// (β-catenin). Project label keeps the requested 'ctbnn1' spelling; the mapped
// gene is the real HGNC symbol CTNNB1. Same mapping thresholds as full discanvis.
params {
    outdir         = 'results/individual_run_ctbnn1'
    target_gene    = 'CTNNB1'
    mapping_mode   = 'all_isoform_mapping'
    blast_coverage = 80
    idmap_coverage = 95
    seq_cutoff     = 80

    blat_chunks    = 1
    scatter_chunks = 1
    per_gene_md_threshold = 50

    fetch_cbioportal = true
}

// --project individual_run_raf1: standalone single-gene run for RAF1.
// Same mapping thresholds as the full discanvis proteome so the output is
// directly comparable, but sized for one gene (no BLAT/scatter parallelism).
params {
    outdir         = 'results/individual_run_raf1'
    target_gene    = 'RAF1'
    mapping_mode   = 'all_isoform_mapping'
    blast_coverage = 80
    idmap_coverage = 95
    seq_cutoff     = 80

    // Single gene → a handful of isoforms; parallel chunks add no benefit.
    blat_chunks    = 1
    scatter_chunks = 1
    per_gene_md_threshold = 50

    // cBioPortal somatic mutations via REST API (no study id needed).
    fetch_cbioportal = true
}

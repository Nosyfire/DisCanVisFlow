// --project test_one_protein: Single-protein test (default TP53, override with --target_gene RAF1)
params {
    outdir         = 'results/test_one_protein'
    target_gene    = 'TP53'
    mapping_mode   = 'all_isoform_mapping'
    blast_coverage = 90
    idmap_coverage = 80
    seq_cutoff     = 70

    // Single-gene runs have ~5–15 transcripts — no benefit from parallel BLAT/scatter chunks.
    // Overrides the machine config so memory stays at 1 × 4 GB (hg38.2bit) regardless of --machine.
    blat_chunks    = 1
    scatter_chunks = 1

    // Include cBioPortal somatic mutations by default in single-gene tests.
    // Uses the REST API (no --cbioportal_study needed).
    fetch_cbioportal = true
}

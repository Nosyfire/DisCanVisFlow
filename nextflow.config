/*
 * DisCanVisFlow — global configuration (v0.6.0)
 *
 * Direct run:
 *
 *   nextflow run main.nf --project cellular_vulnerability --machine laptop -resume
 *   nextflow run main.nf --project full_discanvis --machine hard -resume
 */

manifest {
    name            = 'discanvisflow'
    description     = 'Disease & Disorder Annotation for Human Protein Isoforms'
    version         = '0.6.0'
    nextflowVersion = '>=23.04'
}

// ---------------------------------------------------------------------------
// Global parameters — all values overridable via CLI (--param value)
// ---------------------------------------------------------------------------
params {

    // ── Run description (written to mapping_summary.md) ───────────────────────
    description = null

    // ── Config axes ──────────────────────────────────────────────────────────
    // Loaded from config/data/<data>.config,
    // config/projects/<project>.config, and config/machines/<machine>.config.
    data    = 'discanvis_data'
    project = 'cellular_vulnerability'
    machine = 'laptop'
    env     = 'conda'
    ram     = null
    queue   = null

    // ── Output ────────────────────────────────────────────────────────────────
    outdir   = 'results'
    gene_dir = null

    // ── Reference file cache directory ────────────────────────────────────────
    ref_dir = "${projectDir}/references"

    // ── Zenodo archive for non-refreshing curated data ────────────────────────
    zenodo_url = null

    // ── Module include-list ───────────────────────────────────────────────────
    // null (default) = run ALL modules — existing behaviour preserved.
    // Set to a comma-separated list to run ONLY those modules plus the backbone
    // (BLAST, SEQUENCE_PROCESS, ANNOTATION_MAP, TRANSCRIPT_MAP always run).
    // Dependencies are auto-resolved: e.g. clinvar_disease → mutations + genome.
    //
    // Available module names:
    //   genome, mutations, clinvar_disease, exon
    //   disorder, coiledcoils, pdb, go, mobidb, pem, ppi, scansite, polymorphism
    //   conservation, dbnsfp, alphamissense, depmap, proteingym, mavedb
    //   cancer_drivers, omim, finches
    //
    // Example: --modules "disorder,dbnsfp,clinvar_disease,ptm"
    //   (ptm is part of ANNOTATION_MAP backbone — always included)
    modules = null

    // ── PDB ───────────────────────────────────────────────────────────────────
    skip_pdb  = false
    pdb_bulk  = false
    sifts_tsv = null

    // ── Low-complexity regions ─────────────────────────────────────────────────
    skip_lcr  = false

    // ── Fetch toggles for large references ───────────────────────────────────
    fetch_hg38_2bit   = false
    fetch_dbsnp       = false      // legacy UCSC dbSnp155Common.bb (~1.8 GiB)
    fetch_dbsnp_vcf   = false      // NCBI latest-release VCF → compact MAF table (~28 GiB download)
    fetch_dbsnp_api   = false      // Ensembl REST API — small runs only (≤ 200 proteins)
    dbsnp_maf         = null       // or set fetch_dbsnp_vcf=true
    fetch_gnomad_vcf  = false      // gnomAD v4.1 exome VCFs per chromosome (~80 GiB total download)
    fetch_gnomad_api  = false      // gnomAD GraphQL API — small runs only (≤ 200 proteins)
    gnomad_maf        = null       // or set fetch_gnomad_vcf=true

    // ── Input FASTAs (null → auto-download from FTP) ─────────────────────────
    uniprot_fasta       = null
    gencode_fasta       = null
    gencode_gtf         = null
    gencode_transcripts = null
    gencode_refseq      = null

    // ── Transcript → UniProt mapping mode ────────────────────────────────────
    // 'main_isoform_mapping': BLAST vs canonical Swiss-Prot only (default)
    // 'all_isoform_mapping':  also add curated isoforms (needs uniprot_isoform_fasta)
    mapping_mode          = 'main_isoform_mapping'
    uniprot_isoform_fasta = null

    // ── Genome reference (Module 3) ───────────────────────────────────────────
    hg38_2bit = null   // or set fetch_hg38_2bit=true

    // ── FTP source URLs (GENCODE pinned to v44 for coordinate consistency) ────
    uniprot_ftp_url          = 'https://ftp.uniprot.org/pub/databases/uniprot/current_release/knowledgebase/reference_proteomes/Eukaryota/UP000005640/UP000005640_9606.fasta.gz'
    gencode_release          = 44
    gencode_translations_url = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/gencode.v44.pc_translations.fa.gz'
    gencode_transcripts_url  = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/gencode.v44.pc_transcripts.fa.gz'
    gencode_gtf_url          = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/gencode.v44.chr_patch_hapl_scaff.annotation.gtf.gz'
    gencode_refseq_url       = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/gencode.v44.metadata.RefSeq.gz'

    // ── Gene selection ────────────────────────────────────────────────────────
    // null = full proteome; "RAF1" = single; "RAF1,TP53" = subset
    // gene_list_file overrides target_gene (one HGNC name per line, # comments OK)
    target_gene    = null
    gene_list_file = null

    // ── BLAST+ ────────────────────────────────────────────────────────────────
    blast_bin      = ''
    blast_coverage = 90
    blast_database = 'Gencode'
    idmap_coverage = 95

    // ── Sequence Process (Module 2) ───────────────────────────────────────────
    seq_cutoff = 80

    // ── Genome Mapping (Module 3) ─────────────────────────────────────────────
    blat_min_identity = 95
    blat_min_coverage = 25
    genome_map_cpus   = 24

    // ── Mutation Mapping (Module 4) ───────────────────────────────────────────
    clinvar_vcf      = null   // null → auto-download via FETCH_CLINVAR
    mutation_maf     = null
    mutation_vcf     = null
    mutation_source  = 'ClinVar'
    tcga_maf         = null
    cbioportal_maf   = null
    fetch_cbioportal = false
    cbioportal_study = null
    cbioportal_url   = null
    no_isoform_expand                = false
    mutation_validate_hgvsp          = true
    mutation_hypermutation_threshold = 1500

    // ── Annotation Mapping (Module 5) — curated data sources ─────────────────
    elm_tsv          = "${projectDir}/legacy_data/elm/elm_instances-2023.tsv"
    elm_classes_tsv  = null
    elm_switches_tsv = null
    dibs_tsv         = "${projectDir}/legacy_data/dibs/dibs_parsed.tsv"
    mfib_tsv         = "${projectDir}/legacy_data/mfib/mfib_parsed.tsv"
    phasepro_tsv     = "${projectDir}/legacy_data/phasepro/phasepro_parsed.tsv"
    mobidb_tsv       = null   // null → FETCH_MOBIDB (API, cached)
    legacy_ptmdb_dir  = "${projectDir}/legacy_data/ptm/ptmdb"
    legacy_ptmphs_dir = "${projectDir}/legacy_data/ptm/ptmphs"
    skip_uniprot_api     = false
    skip_pfam_api        = false
    annotation_api_delay = 0.5
    fetch_uniprot_dat    = true
    fetch_interpro_pfam  = true
    uniprot_dat_gz       = null
    interpro_pfam_dat_gz = null

    // ── External programs (disorder predictors) ───────────────────────────────
    ext_programs    = null
    aiupred_python  = null
    deepcoil_python = null
    auto_setup      = false
    iupred3_url     = null

    // ── Disorder Mapping (Module 5b) ──────────────────────────────────────────
    skip_alphafold              = false
    skip_iupred                 = false
    skip_aiupred                = false
    fetch_alphafold_bulk        = false
    alphafold_tar               = null
    alphafold_precomputed_table = null  // Protein_ID|Plldtscores TSV from a prior run — skips EBI API
    only_main_isoforms          = false
    disorder_api_delay          = 0.5

    // ── Scatter (parallelise heavy per-isoform steps) ─────────────────────────
    scatter_chunks        = 1
    blat_chunks           = 1
    per_gene_md_threshold = 50

    // ── Coiled Coils (Module 5i) — DeepCoil; skip on Blackwell GPUs ──────────
    skip_coiledcoils = false

    // ── PPI (Module 5j) ───────────────────────────────────────────────────────
    ppi_intact  = null   // null → FETCH_INTACT → PPI_PREPROCESS
    ppi_biogrid = null
    ppi_hippie  = null
    skip_ppi    = false

    // ── Conservation (Module 7) ───────────────────────────────────────────────
    gopher_conservation_table = null
    run_gopher                = false
    gopher_aln_dir            = null
    gopher_cmd                = null
    gopher_taxon_map          = null
    phastcons_dir             = null   // chr*.bw bigWig dir
    bigwigtobedgraph          = "bigWigToBedGraph"
    skip_phastcons            = false
    skip_conservation         = false

    // ── ScanSite (Module 5k) ──────────────────────────────────────────────────
    scansite_tsv        = null
    scansite_use_api    = true
    scansite_stringency = "High"
    skip_scansite       = false

    // ── Population SNP (Module 5l) ────────────────────────────────────────────
    snp_pos_tsv = null
    skip_snp    = false

    // ── Polymorphism (Module 5g) — dbSNP bigBed ──────────────────────────────
    snp_out_common    = null
    snp_out_all       = null
    dbsnp_bb          = null   // or set fetch_dbsnp=true
    ucsc_bin          = null
    skip_polymorphism = false

    // ── Disease ontology (Modules 8a–8b) ─────────────────────────────────────
    mondo_obo                      = null   // null → FETCH_MONDO
    clinvar_disease_from_mutations = true
    clinvar_disease_tsv            = null
    clinvar_category_tsv           = null
    omim_tsv                       = null
    omim_mutations_tsv             = null
    skip_clinvar_disease           = false
    skip_omim                      = false
    fetch_omim                     = false
    humsavar_url                   = null
    omim_download_key              = null
    omim_url                       = null
    omim_raw_dir                   = null

    // ── Cancer drivers (Module 8c) ────────────────────────────────────────────
    cancer_driver_tsv     = "${projectDir}/legacy_data/drivers/cancer_driver.tsv"
    census_roles_tsv      = "${projectDir}/legacy_data/drivers/census_roles.tsv"
    compendium_roles_tsv  = "${projectDir}/legacy_data/drivers/compendium_roles.tsv"
    census_driver_tsv     = null
    compendium_driver_tsv = null
    skip_cancer_drivers   = false

    // ── AlphaMissense (Module 8d) ─────────────────────────────────────────────
    alphamissense_gz   = null   // null → FETCH_ALPHAMISSENSE (~1.1 GB)
    skip_alphamissense = false

    // ── MaveDB (Module 8e) ────────────────────────────────────────────────────
    mavedb_tsv      = null
    skip_mavedb     = false
    fetch_mavedb    = false
    mavedb_raw      = null
    mavedb_max_sets = null

    // ── ProteinGym (Module 8g) ────────────────────────────────────────────────
    proteingym_tsv        = null
    skip_proteingym       = false
    fetch_proteingym      = false
    proteingym_raw        = null
    proteingym_zip_url    = null
    proteingym_max_assays = null

    // ── FINCHES (Module 8h) — CC BY-NC 4.0, off by default ───────────────────
    skip_finches        = true
    finches_python      = null
    finches_lib         = null
    finches_max_seq_len = 3000

    // ── DepMap (Module 8e) ────────────────────────────────────────────────────
    depmap_tsv     = null
    depmap_raw_csv = null
    skip_depmap    = false
    fetch_depmap   = false
    depmap_url     = null
    depmap_release = null

    // ── Pathogenicity / dbNSFP (Module 8f) ───────────────────────────────────
    dbnsfp_tsv        = null
    dbnsfp_raw_dir    = null
    dbnsfp_bed_header = null
    skip_pathogenicity = false
    fetch_dbnsfp      = false
    dbnsfp_url        = null

    // ── PEM Core Motifs (Module 5h) ───────────────────────────────────────────
    pem_dataset           = null
    pem_transfer          = true
    skip_pem              = false
    homology_min_identity = 0.9
}

// ---------------------------------------------------------------------------
// Process resource defaults
// ---------------------------------------------------------------------------
process {
    withLabel: 'process_low' {
        cpus   = 2
        memory = '8 GB'
        time   = '2 h'
    }
    withLabel: 'process_medium' {
        cpus   = 16
        memory = '64 GB'
        time   = '6 h'
    }
    withLabel: 'process_high' {
        cpus   = 24
        memory = '128 GB'
        time   = '12 h'
    }
}

// ---------------------------------------------------------------------------
// Execution + reporting
// ---------------------------------------------------------------------------
executor {
    name   = 'local'
    cpus   = 120
    memory = '1400 GB'
}

// ---------------------------------------------------------------------------
// Axis-based config loading
// ---------------------------------------------------------------------------
includeConfig "${projectDir}/config/data/${params.data}.config"
includeConfig "${projectDir}/config/projects/${params.project}.config"
includeConfig "${projectDir}/config/machines/${params.machine}.config"
includeConfig "${projectDir}/config/envs/${params.env}.config"

timeline { enabled = true; overwrite = true; file = "${params.outdir}/reports/timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/reports/report.html"   }
dag      { enabled = true; overwrite = true; file = "${params.outdir}/reports/dag.html"      }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/reports/trace.tsv"; fields = 'task_id,name,status,exit,submit,start,complete,duration,realtime,cpus,peak_rss,peak_vmem,rchar,wchar' }

workflow.onComplete = {
    def status = workflow.success ? 'SUCCESS' : 'FAILED'
    def genes  = params.target_gene ? params.target_gene.toString().take(80) : 'all'
    println """
================================================
 DisCanVisFlow  ${status}
  Run ID      : ${workflow.runName}
  Description : ${params.description ?: '—'}
  Duration    : ${workflow.duration}
  Start       : ${workflow.start}
  Project     : ${params.project}
  Data        : ${params.data}
  Machine     : ${params.machine}
  Env         : ${params.env}
  Outdir      : ${params.outdir}
  Gene(s)     : ${genes}
  Reports     : ${params.outdir}/reports/
================================================
""".stripIndent()
}

workflow.onError = {
    println "Pipeline FAILED: ${workflow.errorMessage}"
}

/*
 * DisCanVis Nextflow Pipeline — global configuration  (v0.5.0)
 *
 * ── COMPOSABLE PROFILES ────────────────────────────────────────────────────
 *
 * Environment profiles  (choose exactly one):
 *   conda   — Conda/Mamba environment from environment.yml  ← HPC without Docker
 *   docker  — Docker container discanvis-pipeline:latest
 *
 * Run profiles  (choose exactly one):
 *   raf1    — Local v44 FASTAs + RAF1 single-gene test (~5-10 min)
 *   full    — FTP download of GENCODE v49 + full human proteome
 *
 * Combine with a comma:
 *   nextflow run main.nf -profile raf1,conda       # recommended on HPC
 *   nextflow run main.nf -profile raf1,docker      # if Docker available
 *   nextflow run main.nf -profile full,conda
 *
 * ── DOCKER IMAGE ───────────────────────────────────────────────────────────
 *   Build once:  docker build -t discanvis-pipeline:latest .
 *
 * ── CONDA ENVIRONMENT ──────────────────────────────────────────────────────
 *   Nextflow creates + caches it automatically on first run (~10 min).
 *   Manual create:  conda env create -f environment.yml
 *   Cache location: $NXF_CONDA_CACHEDIR  (or ~/.nextflow/conda by default)
 */

manifest {
    name        = 'nextflow_discanvis'
    description = 'Modular DisCanVis data processing pipeline (DSL2)'
    version     = '0.5.0'
    nextflowVersion = '>=23.04'
}

// ---------------------------------------------------------------------------
// Global parameters
// ---------------------------------------------------------------------------
params {

    // Output root. Predefined project profiles set outdir = "results/<project>"
    // so each named run lands in its own folder under results/.
    outdir = 'results'
    project = null      // logical project name (set by project profiles)
    skip_pdb = false    // skip PDB structure mapping (expensive PDBe API calls)
    pdb_bulk = false    // use SIFTS bulk join instead of per-protein PDBe API (~1000× faster)
    sifts_tsv = null    // local pdb_chain_uniprot.tsv(.gz); null → FETCH_SIFTS downloads it
    fetch_hg38_2bit = false  // when hg38_2bit unset: download hg38.2bit (~797 MiB) via FETCH_HG38_2BIT
    fetch_dbsnp     = false  // when dbsnp_bb unset: download dbSnp155Common.bb (~1.83 GiB) via FETCH_DBSNP_BB

    // ── Zenodo archive for non-refreshing curated data (discanvis_data profile) ──
    zenodo_url = null   // direct download URL of the discanvis_legacy_*.tar.gz record

    // ── Reference file cache directory ────────────────────────────────────────
    ref_dir = "${projectDir}/references"

    // ── Input FASTAs (leave null → auto-download from FTP) ───────────────────
    uniprot_fasta       = null
    gencode_fasta       = null
    gencode_gtf         = null
    gencode_transcripts = null
    gencode_refseq      = null

    // ── Transcript → UniProt mapping mode ─────────────────────────────────────
    // 'main_isoform_mapping' (default): BLAST GENCODE transcripts against the
    //   canonical Swiss-Prot proteome only; every transcript maps to the
    //   canonical accession (the better-curated reference for the main isoform).
    // 'all_isoform_mapping': also add curated Swiss-Prot isoforms (sp|Pxxxxx-N|)
    //   from `uniprot_isoform_fasta` to the BLAST DB and pair each transcript to
    //   its closest isoform (canonical or alternative, e.g. P04049-2).
    mapping_mode          = 'main_isoform_mapping'
    uniprot_isoform_fasta = null   // UniProt 'additional' FASTA (UP000005640_9606_additional.fasta)

    // ── Genome reference for Module 3 ─────────────────────────────────────────
    hg38_2bit = null    // path to hg38.2bit; must be set in raf1 / full profiles

    // ── FTP source URLs ───────────────────────────────────────────────────────
    uniprot_ftp_url          = 'https://ftp.uniprot.org/pub/databases/uniprot/current_release/knowledgebase/reference_proteomes/Eukaryota/UP000005640/UP000005640_9606.fasta.gz'
    // GENCODE is PINNED to release 44 for reproducibility: all pre-mapped data
    // (AlphaMissense / dbNSFP / isoform tables) are v44-coordinate. Do NOT use
    // latest_release — a newer GENCODE breaks coordinate consistency.
    gencode_release          = 44
    gencode_translations_url = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/gencode.v44.pc_translations.fa.gz'
    gencode_transcripts_url  = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/gencode.v44.pc_transcripts.fa.gz'
    gencode_gtf_url          = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/gencode.v44.chr_patch_hapl_scaff.annotation.gtf.gz'
    gencode_refseq_url       = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/gencode.v44.metadata.RefSeq.gz'

    // ── Gene selection ───────────────────────────────────────────────────────
    // target_gene: null = full proteome; "RAF1" = single gene; "RAF1,TP53" = subset
    // gene_list_file: path to a plain-text file (one gene per line) — loaded at
    //   startup and merged into target_gene as a comma-separated string.
    //   Takes precedence over target_gene when set.
    target_gene    = null
    gene_list_file = null

    // ── BLAST+ binary path ────────────────────────────────────────────────────
    // Empty string → use BLAST+ from PATH (correct for conda and docker).
    // Set to a directory path only when running without conda/docker on a host
    // that has BLAST+ installed in a non-standard location.
    blast_bin = ''

    // ── BLAST parameters ──────────────────────────────────────────────────────
    blast_coverage = 90
    blast_database = 'Gencode'
    idmap_coverage = 95

    // ── Sequence Process parameters (Module 2) ────────────────────────────────
    seq_cutoff = 80    // minimum coverage % for isoform selection

    // ── Genome Mapping parameters (Module 3) ──────────────────────────────────
    blat_min_identity = 95     // minimum % identity for BLAT alignment
    blat_min_coverage = 25     // minimum % coverage for pslCDnaFilter
    genome_map_cpus   = 24     // parallel workers in create_genome_map_worker.py

    // ── Mutation Mapping (Module 4) ───────────────────────────────────────────
    // ClinVar VCF: provide a local path or leave null to auto-download
    clinvar_vcf     = null
    // MAF file (legacy single-source). Prefer tcga_maf / cbioportal_maf for cancer cohorts.
    mutation_maf    = null
    // Generic VCF (non-ClinVar). Mutually exclusive with clinvar_vcf / mutation_maf.
    mutation_vcf    = null
    mutation_source = 'ClinVar'    // label when using mutation_maf / mutation_vcf alone
    // Cancer MAF inputs (hg38); mapped in parallel with ClinVar when all are set.
    tcga_maf        = null
    cbioportal_maf  = null
    // Reproducible cBioPortal path: fetch_cbioportal=true pulls a public study
    // bundle from the cBioPortal datahub (FETCH_CBIOPORTAL) → data_mutations MAF.
    fetch_cbioportal  = false
    cbioportal_study  = null   // datahub study id, e.g. 'msk_impact_2017'
    cbioportal_url    = null   // or a full study tarball URL

    // ── Annotation Mapping (Module 5) — legacy data sources ──────────────────
    // ELM / DIBS / MFIB / PhasePro come from project-local legacy_data/
    elm_tsv        = "${projectDir}/legacy_data/elm/elm_instances-2023.tsv"
    // ELM class definitions for ElmProteomeClassMatch (null = use legacy_data default)
    elm_classes_tsv = null
    // ELM molecular switches for Elm_Switches (null = use legacy_data default)
    elm_switches_tsv = null
    dibs_tsv      = "${projectDir}/legacy_data/dibs/dibs_parsed.tsv"
    mfib_tsv      = "${projectDir}/legacy_data/mfib/mfib_parsed.tsv"
    phasepro_tsv  = "${projectDir}/legacy_data/phasepro/phasepro_parsed.tsv"
    mobidb_tsv    = null   // null = download from MobiDB API via FETCH_MOBIDB

    // PTM local directories (from legacy_data/ptm/)
    legacy_ptmdb_dir  = "${projectDir}/legacy_data/ptm/ptmdb"
    legacy_ptmphs_dir = "${projectDir}/legacy_data/ptm/ptmphs"

    // UniProt / Pfam API toggles
    skip_uniprot_api     = false
    skip_pfam_api        = false
    annotation_api_delay = 0.5

    // Bulk FTP pre-parse: replaces per-protein REST API calls (ANNOTATION_MAP).
    // fetch_uniprot_dat=true (default) → FETCH_UNIPROT_SPROT_DAT auto-downloads.
    // fetch_interpro_pfam=true (default) → FETCH_INTERPRO_PFAM auto-downloads.
    // Supply local paths to skip the download step.
    fetch_uniprot_dat    = true   // auto-download uniprot_sprot.dat.gz
    fetch_interpro_pfam  = true   // auto-download protein2ipr.dat.gz
    uniprot_dat_gz       = null   // supply a local path to skip download
    interpro_pfam_dat_gz = null   // supply a local path to skip download

    // ── One-time machine setup (SETUP_DEPS process) ───────────────────────────
    // auto_setup=true → run SETUP_DEPS on first launch: clones AIUPred from GitHub,
    // creates discanvis_aiupred + discanvis_deepcoil conda envs, installs bigBedToBed.
    // Outputs are storeDir-cached inside ext_programs/.nf_setup_done so SETUP_DEPS
    // is skipped on every subsequent run. Set false if setup was done manually.
    auto_setup   = false   // enabled per-profile below (true in 'discanvis_data')
    iupred3_url  = null    // optional: URL to iupred3.tar.gz hosted by the group

    // ── Disorder Mapping (Module 5b) ──────────────────────────────────────────
    // Path to DisCanVis_Data_Process/External_Programs/ (IUPred3, AIUPred, AIUPred-Binding)
    // Must be set in a run profile or via --ext_programs on the CLI.
    ext_programs     = null    // e.g. /path/to/DisCanVis_Data_Process/External_Programs
    // Python binary with scipy+torch for subprocess-based IUPred3/AIUPred predictions.
    // Leave null when auto_setup=true — the path is auto-detected from the setup env.
    aiupred_python   = null    // e.g. /path/to/conda/envs/discanvis_aiupred/bin/python
    deepcoil_python  = null    // e.g. /path/to/conda/envs/discanvis_deepcoil/bin/python
    skip_alphafold       = false   // set true to skip AlphaFold pLDDT entirely
    skip_iupred          = false   // set true to skip IUPred3/ANCHOR2
    skip_aiupred         = false   // set true to skip AIUPred/AIUPred-Binding
    // Bulk AlphaFold pLDDT extraction (replaces per-protein EBI API calls).
    fetch_alphafold_bulk = false   // auto-download UP000005640_9606_HUMAN_v*.tar
    alphafold_tar        = null    // supply a local tar path to skip download
    only_main_isoforms = false // set true to only map annotations to main isoform
    disorder_api_delay = 0.5   // seconds between AlphaFold API requests

    // ── Scatter (parallelise the per-isoform heavy steps for large runs) ─────
    // 1 = single task (default, unchanged). >1 splits the sequence table into
    // this many gene-balanced chunks so DISORDER_MAP + COILEDCOILS_MAP run as K
    // concurrent tasks (cap local concurrency with executor.cpus / process
    // maxForks; on -profile slurm each chunk is its own job). For a ~20 k
    // proteome set this to e.g. 100–500 with the slurm profile to turn a ~10-day
    // serial run into hours. A collectFile merge re-assembles the published tables.
    scatter_chunks = 1

    // MAPPING_REPORT: write per-gene <GENE>_mapping_report.md only when gene count
    // is at or below this threshold. Above it, writes mapping_coverage.tsv (flat TSV)
    // instead — avoids generating 19k files for full-proteome runs.
    per_gene_md_threshold = 50

    // Number of parallel BLAT jobs for genome mapping (Module 3).
    // blat_chunks > 1 splits the cDNA FASTA into N chunks → N concurrent BLAT
    // processes → N× speedup on a multi-core machine.  Recommended: 8–16 locally.
    blat_chunks    = 1

    // ── CoiledCoils (Module 5i) ───────────────────────────────────────────────
    skip_coiledcoils = false   // set true to skip DeepCoil prediction

    // ── PPI (Module 5j) ───────────────────────────────────────────────────────
    // Pre-processed interaction tables; null = auto-download raw + preprocess
    ppi_intact  = null
    ppi_biogrid = null
    ppi_hippie  = null
    skip_ppi    = false

    // ── Conservation (Module 7) ───────────────────────────────────────────────
    // GOPHER multi-level conservation table (pre-computed, no public download)
    // null = skip GOPHER conservation (phastCons still runs if phastcons_dir set)
    gopher_conservation_table = null
    // GOPHER RECOMPUTE (run_gopher=true): rebuild the conservation table from
    // orthologue alignments instead of consuming the precomputed one. Slow.
    //   gopher_aln_dir  : dir of <ACC>.orthaln.fas orthologue alignments, OR
    //   gopher_cmd      : command template to run real GOPHER/SLiMSuite + a
    //                     proteome DB ({fasta}/{aln_dir} substituted) to build them.
    //   gopher_taxon_map: species→levels TSV (null = built-in default set).
    run_gopher       = false
    gopher_aln_dir   = null
    gopher_cmd       = null
    gopher_taxon_map = null
    // phastCons bigWig directory (chr1.bw … chrY.bw); null = skip phastCons
    phastcons_dir      = null
    bigwigtobedgraph   = "bigWigToBedGraph"  // binary in PATH (or full path)
    skip_phastcons     = false
    skip_conservation  = false   // set true to skip entire Module 7

    // ── ScanSite (Module 5k) ─────────────────────────────────────────────────
    scansite_tsv        = null   // null = use API (default) or set path to pre-computed TSV
    scansite_use_api    = true   // call MIT ScanSite 4 API (default); set false + provide scansite_tsv for pre-computed
    scansite_stringency = "High" // High | Medium | Low
    skip_scansite       = false

    // ── Population SNP polymorphisms (Module 5l) ─────────────────────────────
    // null = skip (no public auto-download; derive from ClinVar/gnomAD manually)
    snp_pos_tsv = null
    skip_snp    = false

    // ── Polymorphism (Module 5g) — legacy SNP .out tables, mapped via combined_map ─
    // null = empty output (set in run profiles). Replaces the UniProt REST API.
    snp_out_common = null
    snp_out_all    = null
    // Preferred source: dbSnp*Common.bb bigBed — polymorphisms (rsid + allele
    // frequency) extracted per selected isoform via combined_map. ucsc_bin = dir
    // holding bigBedToBed (null → PATH).
    dbsnp_bb       = null
    ucsc_bin       = null
    skip_polymorphism = false

    // ── Disease ontology (Modules 8a-8b) ─────────────────────────────────────
    mondo_obo = null   // null = FETCH_MONDO auto-downloads from GitHub
    clinvar_disease_from_mutations = true   // build from MUTATION_MAP + MONDO OBO when hg38 set
    clinvar_disease_tsv  = null   // null = skip static filter table (use from_mutations path)
    clinvar_category_tsv = null   // null = skip ClinVar category table
    omim_tsv             = null   // null = skip OMIM mapping (requires manual setup)
    omim_mutations_tsv   = null   // null = skip OMIM mutations
    skip_clinvar_disease = false
    skip_omim            = false
    // Reproducible OMIM path: download the raw OMIM files with your per-user key
    // (FETCH_OMIM) → create_omim_worker.py --mapping_mode raw (genemap2 parse).
    // OMIM mutations come from UniProt humsavar.txt (OPEN — no key). The OMIM
    // genemap2 disease ontology is optional and key-gated.
    fetch_omim         = false
    humsavar_url       = null     // UniProt humsavar.txt (null = current_release default)
    omim_download_key  = null     // optional OMIM per-user key (genemap2 enrichment)
    omim_url           = null     // or a full base URL / mirror for the raw OMIM files
    omim_raw_dir       = null     // local dir of raw files (humsavar.txt / genemap2.txt) → raw parse

    // ── Cancer drivers (Module 8c) ────────────────────────────────────────────
    // Combined legacy file (Protein_ID + 'Cancer Driver' = Census/Compendium),
    // vendored into the repo since it is small (~90 KB). Worker splits it into
    // census_driver.tsv + compendium_driver.tsv.
    cancer_driver_tsv     = "${projectDir}/legacy_data/drivers/cancer_driver.tsv"
    // Gene-keyed role tables (vendored, small) — supply the actual driver role
    // (CGC 'Role in Cancer' / tumour types; Compendium ROLE + cancer types).
    census_roles_tsv      = "${projectDir}/legacy_data/drivers/census_roles.tsv"
    compendium_roles_tsv  = "${projectDir}/legacy_data/drivers/compendium_roles.tsv"
    // Legacy pre-split inputs (fallback only); null = unused
    census_driver_tsv     = null
    compendium_driver_tsv = null
    skip_cancer_drivers   = false

    // ── AlphaMissense GENCODE isoforms (Module 8d) ───────────────────────────
    // null = FETCH_ALPHAMISSENSE auto-downloads from Google Cloud Storage (~1.1 GB)
    alphamissense_gz   = null
    skip_alphamissense = false

    // ── MaveDB single-mutant functional scores (mapped) ──────────────────────
    // Pre-mapped (Protein_ID-keyed) MaveDB table; null = skip. Set in profiles.
    mavedb_tsv  = null
    skip_mavedb = false
    // Reproducible path: fetch_mavedb=true pulls fresh from api.mavedb.org
    // (FETCH_MAVEDB) and MAVEDB_MAP runs --mapping_mode uniprot (isoform fan-out).
    // mavedb_raw lets you supply a pre-fetched UniProt-keyed raw table instead.
    fetch_mavedb     = false
    mavedb_raw       = null
    mavedb_max_sets  = null        // cap score-sets enumerated (test runs)

    // ── ProteinGym DMS scores + pathogenicity proxy (Module 8g) ──────────────
    // Pre-mapped (Protein_ID-keyed) ProteinGym substitutions table; null = skip.
    proteingym_tsv  = null
    skip_proteingym = false
    // Reproducible path: fetch_proteingym=true downloads the substitution DMS
    // assays (FETCH_PROTEINGYM) and PROTEINGYM_MAP runs --mapping_mode uniprot.
    fetch_proteingym      = false
    proteingym_raw        = null
    proteingym_zip_url    = null   // override the substitutions zip URL
    proteingym_max_assays = null   // cap assays parsed (test runs)

    // ── FINCHES site-wise Δε LLPS-change score (Module 8h) ───────────────────
    // Saturation mutagenesis using Mpipi_GGv1 force field.  Off by default
    // (expensive; CC BY-NC 4.0 — non-commercial only).
    // Set finches_lib to the cloned finches repo root if not on sys.path.
    // Set finches_python to a Python executable that has the finches library
    // installed (e.g. params.aiupred_python env, or a dedicated conda env).
    skip_finches          = true
    finches_python        = null   // null = use 'python' on PATH
    finches_lib           = null   // null = assume 'finches' is on sys.path
    finches_max_seq_len   = 3000   // proteins longer than this are skipped

    // ── DepMap cancer cell line mutations (Module 8e) ─────────────────────────
    // null = skip (DepMap requires login/versioned URL; download manually from
    //   https://depmap.org/portal/download → OmicsSomaticMutations.csv,
    //   pre-process with create_depmap_worker.py --depmap_raw, set path here)
    depmap_tsv  = null
    skip_depmap = false
    // DepMap is OPEN data: fetch_depmap=true resolves + downloads the newest
    // OmicsSomaticMutations.csv via the DepMap catalogue (FETCH_DEPMAP).
    fetch_depmap   = false
    depmap_url     = null     // direct CSV URL/path (skip catalogue resolution)
    depmap_release = null     // pin a release, e.g. 'DepMap Public 26Q1'

    // ── Pathogenicity predictors / dbNSFP (Module 8f) ────────────────────────
    // dbnsfp_tsv: pre-filtered TSV (null = skip filter path)
    // dbnsfp_raw_dir: directory with chr*.gz raw dbNSFP files (preferred, null = skip)
    dbnsfp_tsv        = null
    dbnsfp_raw_dir    = null
    dbnsfp_bed_header = null
    skip_pathogenicity = false
    // Reproducible dbNSFP path: fetch_dbnsfp=true downloads + unzips the raw
    // academic dbNSFP distribution (FETCH_DBNSFP) into dbnsfp_raw_dir.
    fetch_dbnsfp = false
    dbnsfp_url   = null       // academic dbNSFP zip URL (or Zenodo mirror)

    // ── Mutation mapping (Module 4) ───────────────────────────────────────────
    no_isoform_expand = false  // set true to map to primary transcript only (faster)
    mutation_validate_hgvsp = true          // HGVSp ref-AA check vs combined_map.map (TCGA/cBio)
    mutation_hypermutation_threshold = 1500 // drop hypermutated MAF samples (0=disable)

    // ── PEM Core Motifs (Module 5h) ───────────────────────────────────────────
    // null = skip (IDP paper supplementary file; no public auto-download)
    pem_dataset  = null
    pem_transfer = true   // map PEM motifs to alternative isoforms via sequence homology
    skip_pem     = false

    // Min sequence identity for region/structure homology transfer to an
    // alternative isoform (TRANSCRIPT_MAP / PDB_BULK_MAP). Documented default 0.90.
    homology_min_identity = 0.9

    // ── Output structure ──────────────────────────────────────────────────────
    // gene_dir: optional sub-path under outdir for per-gene results.
    // Set to 'chrN/genename' in single-gene profiles; leave null for proteome runs.
    // e.g.: results/chr3/raf1/unmapped/annotations/
    gene_dir = null
}

// ---------------------------------------------------------------------------
// Process resource labels  (overridden per environment profile below)
// ---------------------------------------------------------------------------
process {
    withLabel: 'process_low' {
        cpus   = 2
        memory = '8 GB'
        time   = '2 h'
    }
    withLabel: 'process_medium' {
        cpus   = 16
        memory = '64 GB'
        time   = '6 h'
    }
    withLabel: 'process_high' {
        cpus   = 24
        memory = '128 GB'
        time   = '12 h'
    }
}

// ---------------------------------------------------------------------------
// Profiles
// ---------------------------------------------------------------------------
profiles {

    // ════════════════════════════════════════════════════════════════════════
    // ENVIRONMENT PROFILES  —  combine with a run profile using a comma
    //   e.g.  -profile raf1,conda   or   -profile full,docker
    // ════════════════════════════════════════════════════════════════════════

    // ── Conda  (recommended on shared HPC without Docker) ────────────────────
    // Strategy (in order of preference):
    //  1. If a conda env is already ACTIVE ($CONDA_PREFIX is set), use it
    //     directly — no new environment is created, no cache dir needed.
    //  2. Otherwise Nextflow creates an env from environment.yml and caches
    //     it in $NXF_CONDA_CACHEDIR or ~/.nextflow/conda.
    //
    // Recommended workflow:
    //   conda activate discanvis
    //   nextflow run main.nf -profile raf1,conda
    conda {
        conda.enabled      = true
        conda.createTimeout = '30 min'
        // Use the currently active conda environment when CONDA_PREFIX is set;
        // fall back to building from environment.yml for a fresh install.
        process.conda      = System.getenv('CONDA_PREFIX') ?: "${projectDir}/environment.yml"
        // Store conda envs created by Nextflow in a stable project-local dir
        // (avoids putting cache inside workDir which may not exist yet).
        conda.cacheDir     = "${projectDir}/.nextflow-conda-cache"
        params.blast_bin   = ''
    }

    // ── Docker ───────────────────────────────────────────────────────────────
    // Build image first:  docker build -t discanvis-pipeline:latest .
    docker {
        docker.enabled    = true
        docker.runOptions = '--rm -u $(id -u):$(id -g)'
        process.container = 'discanvis-pipeline:latest'
        // BLAST+ is at /opt/ncbi-blast-2.13.0+/bin inside the container,
        // which is added to PATH in the Dockerfile via ENV.
        params.blast_bin  = ''
    }

    // ════════════════════════════════════════════════════════════════════════
    // RUN PROFILES  —  define data inputs and workDir
    // ════════════════════════════════════════════════════════════════════════

    // ── RAF1 single-gene test ─────────────────────────────────────────────────
    // Local GENCODE v44 + UniProt FASTA files (~5-10 min end-to-end).
    // All machine-specific paths are set here; global params stay null for portability.
    raf1 {
        params {
            uniprot_fasta       = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/UP000005640_9606.fasta'
            uniprot_isoform_fasta = '/dlab/home/norbi/Bori_DiplomaMunka/external_data/UP000005640_9606_additional.fasta'
            gencode_fasta       = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.pc_translations.fa'
            gencode_gtf         = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.chr_patch_hapl_scaff.annotation.gtf.gz'
            gencode_transcripts = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.pc_transcripts.fa'
            gencode_refseq      = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.metadata.RefSeq'
            hg38_2bit           = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/hg38/hg38.2bit'
            target_gene         = 'RAF1'
            blast_coverage      = 90
            idmap_coverage      = 80
            seq_cutoff          = 70
            outdir              = 'results'
            gene_dir            = 'chr3/raf1'

            // ── Disorder / CoiledCoils (machine-specific library paths) ──────
            ext_programs    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Programs'
            aiupred_python  = '/opt/anaconda3/envs/aiupred/bin/python'
            deepcoil_python = null   // no discanvis_deepcoil env on this server yet; coiledcoils degrades gracefully
            // FINCHES shares the aiupred env (finches installable via pip there)
            finches_python  = '/opt/anaconda3/envs/aiupred/bin/python'
            finches_lib     = '/dlab/home/norbi/PycharmProjects/Finches/finches-main'

            // ── PPI (local pre-processed) ────────────────────────────────────
            ppi_intact  = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/interactions/Interaction_intact.tsv'
            ppi_biogrid = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/interactions/Interaction_biogrid.tsv'
            ppi_hippie  = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/interactions/Interaction_hippie.tsv'

            // ── Conservation (local pre-computed) ────────────────────────────
            gopher_conservation_table = '/dlab/home/norbi/data/Gopher/DisCanVis2/quefo/HUMAN/conservation/conservation_table.tsv'
            phastcons_dir             = '/dlab/home/norbi/data/phastcons'

            // ── ClinVar VCF (local, avoids FTP re-download) ──────────────────

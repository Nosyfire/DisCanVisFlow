            // ── dbNSFP (pre-mapped, Protein_ID-keyed) ─────────────────────────
            dbnsfp_tsv          = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/dbNSFP_custom/mapped_filtered_mutations.tsv'

            // ── SNP polymorphisms (local pre-processed) ───────────────────────
            snp_pos_tsv = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/positional_data_process/polymorphism_pos.tsv'
            snp_out_common = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/SNP/common_poly.out'
            snp_out_all    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/SNP/all_poly.out'
            dbsnp_bb       = '/home/nosyfire/data/snp/155/dbSnp155Common.bb'
            ucsc_bin       = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Programs/UCSC/UCSC_utils_64'

            // ── PEM Core Motifs (local paper supplementary) ───────────────────
            pem_dataset = '/dlab/home/norbi/paper_projects/IDP_Pathogenic_Mutations/processed_data/files/supplementary/predicted_elm_dataset.tsv'

            // ── ScanSite fallback (local pre-computed; API is default) ─────────
            scansite_tsv = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/annotations/domains_and_motifs/scansite.tsv'
        }
        workDir          = '/dlab/home/norbi/PycharmProjects/discanvis_gencode_nextflow_raf1'
        process.executor = 'local'
        process {
            withLabel: 'process_medium' { cpus = 4; memory = '8 GB';  time = '30 min' }
            withLabel: 'process_high'   { cpus = 4; memory = '16 GB'; time = '1 h'    }
        }
    }

    // ── Full proteome run ─────────────────────────────────────────────────────
    // Downloads GENCODE v49 (latest) + UniProt from FTP (cached in ref_dir).
    // No target_gene subsetting → processes entire human proteome.
    // Machine-specific paths (ext_programs, ppi_*, conservation, etc.) must be
    // set via CLI --params-file or added to this profile for your installation.
    full {
        params {
            // All FASTA/GTF params left null → FTP download triggered
            hg38_2bit    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/hg38/hg38.2bit'
            target_gene  = null
            blast_coverage  = 80   // 80 avoids filtering genes where GENCODE > UniProt length
            idmap_coverage  = 95
            seq_cutoff      = 80
            outdir          = 'results_full'
            // Machine-specific paths (same as raf1 profile for this installation)
            ext_programs    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Programs'
            aiupred_python  = '/opt/anaconda3/envs/aiupred/bin/python'
            deepcoil_python = null
            finches_python  = '/opt/anaconda3/envs/aiupred/bin/python'
            finches_lib     = '/dlab/home/norbi/PycharmProjects/Finches/finches-main'
            ppi_intact  = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/interactions/Interaction_intact.tsv'
            ppi_biogrid = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/interactions/Interaction_biogrid.tsv'
            ppi_hippie  = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/interactions/Interaction_hippie.tsv'
            gopher_conservation_table = '/dlab/home/norbi/data/Gopher/DisCanVis2/quefo/HUMAN/conservation/conservation_table.tsv'
            phastcons_dir             = '/dlab/home/norbi/data/phastcons'
            mondo_obo           = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/disease_ontology/mondo/mondo.obo'
            omim_tsv            = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/tables/omim_table_with_ontology_with_annotate.tsv'
            omim_mutations_tsv  = '/dlab/home/norbi/PycharmProjects/Cancer_Visualization_Data_Process/7.2_OMIM_Desease/data/process_gencode/omim_mapped.tsv'
            census_driver_tsv     = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/drivers/census_driver.tsv'
            compendium_driver_tsv = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/drivers/compendium_driver.tsv'
            alphamissense_gz      = '/dlab/home/norbi/PycharmProjects/AlphaMissense/data/AlphaMissense_isoforms_hg38.tsv.gz'
            depmap_tsv            = '/dlab/home/norbi/PycharmProjects/Turbine_Projects/variant_driven_cellular_vulnerability/data/raw/depmap/mapped_filtered_mutations.tsv'
            dbnsfp_tsv        = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/dbNSFP_custom/mapped_filtered_mutations.tsv'
            dbnsfp_bed_header     = '/dlab/home/norbi/PycharmProjects/Cancer_Visualization_Data_Process/31_GENOME_MAP/data/bed/dbNSFP_custom/dbNSFP_custom.bed.header'
            snp_pos_tsv           = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/positional_data_process/polymorphism_pos.tsv'
            snp_out_common = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/SNP/common_poly.out'
            snp_out_all    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/SNP/all_poly.out'
            dbsnp_bb       = '/home/nosyfire/data/snp/155/dbSnp155Common.bb'
            ucsc_bin       = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Programs/UCSC/UCSC_utils_64'
            pem_dataset           = '/dlab/home/norbi/paper_projects/IDP_Pathogenic_Mutations/processed_data/files/supplementary/predicted_elm_dataset.tsv'
        }
        workDir          = '/dlab/home/norbi/PycharmProjects/discanvis_gencode_nextflow_full'
        process.executor = 'local'
    }

    // ── Multi-gene subset test (50 cancer / well-studied genes) ─────────────
    // Uses same machine-specific paths as raf1, but runs 50 genes in parallel.
    // workDir is separate so RAF1 cache is preserved.
    // Activate with:  nextflow run main.nf -profile subset50,conda
    subset50 {
        params {
            // Same FASTA/reference inputs as raf1
            uniprot_fasta       = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/UP000005640_9606.fasta'
            uniprot_isoform_fasta = '/dlab/home/norbi/Bori_DiplomaMunka/external_data/UP000005640_9606_additional.fasta'
            gencode_fasta       = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.pc_translations.fa'
            gencode_gtf         = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.chr_patch_hapl_scaff.annotation.gtf.gz'
            gencode_transcripts = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.pc_transcripts.fa'
            gencode_refseq      = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/gencode.v44.metadata.RefSeq'
            hg38_2bit           = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/hg38/hg38.2bit'

            // 50 cancer / signalling / IDP genes (comma-separated → multi-gene subsetting)
            target_gene = 'TP53,RAF1,CTNNB1,MYC,BRAF,BRCA1,BRCA2,WNK4,EGFR,KRAS,NRAS,HRAS,PIK3CA,PTEN,AKT1,CDK4,CDK6,CDKN2A,MDM2,RB1,VHL,ARID1A,SMAD4,FBXW7,NOTCH1,IDH1,IDH2,DNMT3A,FLT3,NPM1,RUNX1,CEBPA,WT1,SF3B1,SRSF2,U2AF1,ATM,CHEK2,PALB2,RAD51,MSH2,MLH1,MSH6,APC,MUTYH,POLE,ERBB2,ALK,RET,MET'

            blast_coverage = 80   // lowered from 90: genes like WT1 have GENCODE>UniProt length
            idmap_coverage = 80
            seq_cutoff     = 70
            outdir         = 'results_subset50'
            gene_dir       = null   // no per-gene subdir for multi-gene runs

            // ── Disorder / CoiledCoils ──────────────────────────────────────
            ext_programs    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Programs'
            aiupred_python  = '/opt/anaconda3/envs/aiupred/bin/python'
            deepcoil_python = null
            finches_python  = '/opt/anaconda3/envs/aiupred/bin/python'
            finches_lib     = '/dlab/home/norbi/PycharmProjects/Finches/finches-main'

            // ── PPI ─────────────────────────────────────────────────────────
            ppi_intact  = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/interactions/Interaction_intact.tsv'
            ppi_biogrid = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/interactions/Interaction_biogrid.tsv'
            ppi_hippie  = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/interactions/Interaction_hippie.tsv'

            // ── Conservation ─────────────────────────────────────────────────
            gopher_conservation_table = '/dlab/home/norbi/data/Gopher/DisCanVis2/quefo/HUMAN/conservation/conservation_table.tsv'
            phastcons_dir             = '/dlab/home/norbi/data/phastcons'

            // ── ClinVar + cancer MAFs ─────────────────────────────────────────
            clinvar_vcf    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Automated_Pipeline/data/raw/mutations/clinvar/v_2026_03_09/clinvar.vcf.gz'
            tcga_maf       = '/dlab/home/norbi/PycharmProjects/Cancer_Visualization_Data_Process/32_Genome_version_mapping/data/process_cancerviz_01/TCGA_hg38.maf'
            cbioportal_maf = '/dlab/home/norbi/PycharmProjects/Cancer_Visualization_Data_Process/32_Genome_version_mapping/data/process_cancerviz_01/Cbioportal_hg38.maf'

            // ── Disease ontology ─────────────────────────────────────────────
            mondo_obo           = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Data/gencode_process/disease_ontology/mondo/mondo.obo'
            omim_tsv            = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/tables/omim_table_with_ontology_with_annotate.tsv'
            omim_mutations_tsv  = '/dlab/home/norbi/PycharmProjects/Cancer_Visualization_Data_Process/7.2_OMIM_Desease/data/process_gencode/omim_mapped.tsv'

            // ── Cancer drivers ───────────────────────────────────────────────
            census_driver_tsv     = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/drivers/census_driver.tsv'
            compendium_driver_tsv = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/drivers/compendium_driver.tsv'

            // ── AlphaMissense ────────────────────────────────────────────────
            alphamissense_gz = '/dlab/home/norbi/PycharmProjects/AlphaMissense/data/AlphaMissense_isoforms_hg38.tsv.gz'
            mavedb_tsv       = '/dlab/home/norbi/PycharmProjects/Benchmark_Pathogenicity_Predictors/data/mavedb/mave_single_mutant_protein.tsv'
            proteingym_tsv   = '/dlab/home/norbi/PycharmProjects/Benchmark_Pathogenicity_Predictors/data/benchmark/processed_proteingym_results_hg38_mapping_isoforms.tsv'

            // ── DepMap ───────────────────────────────────────────────────────
            depmap_tsv = '/dlab/home/norbi/PycharmProjects/Turbine_Projects/variant_driven_cellular_vulnerability/data/raw/depmap/mapped_filtered_mutations.tsv'

            // ── dbNSFP ───────────────────────────────────────────────────────
            dbnsfp_tsv    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/dbNSFP_custom/mapped_filtered_mutations.tsv'
            dbnsfp_bed_header = '/dlab/home/norbi/PycharmProjects/Cancer_Visualization_Data_Process/31_GENOME_MAP/data/bed/dbNSFP_custom/dbNSFP_custom.bed.header'

            // ── SNP / PEM / ScanSite ─────────────────────────────────────────
            snp_pos_tsv = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/positional_data_process/polymorphism_pos.tsv'
            snp_out_common = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/SNP/common_poly.out'
            snp_out_all    = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/mutation_mapping/SNP/all_poly.out'
            dbsnp_bb       = '/home/nosyfire/data/snp/155/dbSnp155Common.bb'
            ucsc_bin       = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/External_Programs/UCSC/UCSC_utils_64'
            pem_dataset = '/dlab/home/norbi/paper_projects/IDP_Pathogenic_Mutations/processed_data/files/supplementary/predicted_elm_dataset.tsv'
            scansite_tsv = '/dlab/home/norbi/PycharmProjects/DisCanVis_Data_Process/Processed_Data/gencode_process/annotations/domains_and_motifs/scansite.tsv'
        }
        workDir          = '/dlab/home/norbi/PycharmProjects/discanvis_gencode_nextflow_subset50'
        process.executor = 'local'
        process {
            withLabel: 'process_medium' { cpus = 6; memory = '16 GB'; time = '2 h' }
            withLabel: 'process_high'   { cpus = 8; memory = '32 GB'; time = '4 h' }
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // PREDEFINED PROJECT PROFILES
    //   Each names a logical project; outputs land under results/<project>/.
    //   Machine reference/data paths come from conf/local_refs.config.
    //   Combine with an env profile, e.g.:  -profile vep_benchmarking,conda
    //   See PROJECTS.md for details.
    // ════════════════════════════════════════════════════════════════════════

    // ── DisCanVis update — full proteome, all UniProt isoforms ───────────────
    discanvis {
        includeConfig 'conf/local_refs.config'
        params {
            project        = 'discanvis'
            outdir         = 'results/discanvis'
            gene_dir       = null
            target_gene    = null                       // whole human proteome
            mapping_mode   = 'all_isoform_mapping'
            blast_coverage = 80
            idmap_coverage = 95
            seq_cutoff     = 80
        }
        workDir          = '/dlab/home/norbi/PycharmProjects/discanvis_gencode_nextflow_discanvis'
        process.executor = 'local'
        process {
            withLabel: 'process_medium' { cpus = 6; memory = '16 GB'; time = '4 h' }
            withLabel: 'process_high'   { cpus = 8; memory = '32 GB'; time = '8 h' }
        }
    }

    // ── VEP benchmarking — human proteome, benchmark data only ───────────────
    // Keeps: ClinVar, MaveDB, ProteinGym, Combined Disorder, conservation,
    //        dbNSFP/pathogenicity, AlphaMissense. Skips the rest for speed.
    vep_benchmarking {
        includeConfig 'conf/local_refs.config'
        params {
            project        = 'vep_benchmarking'
            outdir         = 'results/vep_benchmarking'
            gene_dir       = null
            target_gene    = null                       // whole human proteome
            mapping_mode   = 'all_isoform_mapping'
            blast_coverage = 80
            idmap_coverage = 95
            seq_cutoff     = 80
            // cancer cohort MAFs not needed — ClinVar only
            tcga_maf       = null
            cbioportal_maf = null
            // focus the run on benchmark-relevant outputs
            skip_pdb          = true
            skip_ppi          = true
            skip_coiledcoils  = true
            skip_scansite     = true
            skip_pem          = true
            skip_cancer_drivers = true
            skip_omim         = true
            skip_depmap       = true
        }
        workDir          = '/dlab/home/norbi/PycharmProjects/discanvis_gencode_nextflow_vep'
        process.executor = 'local'
        process {
            withLabel: 'process_medium' { cpus = 6; memory = '16 GB'; time = '4 h' }
            withLabel: 'process_high'   { cpus = 8; memory = '32 GB'; time = '8 h' }
        }
    }

    // ── Single-protein test (override gene with --target_gene) ───────────────
    test_one_protein {
        includeConfig 'conf/local_refs.config'
        params {
            project        = 'test_one_protein'
            outdir         = 'results/test_one_protein'
            gene_dir       = null
            target_gene    = 'TP53'                      // override: --target_gene RAF1
            mapping_mode   = 'all_isoform_mapping'
            blast_coverage = 90
            idmap_coverage = 80
            seq_cutoff     = 70
        }
        workDir          = '/dlab/home/norbi/PycharmProjects/discanvis_gencode_nextflow_test'
        process.executor = 'local'
        process {
            withLabel: 'process_medium' { cpus = 4; memory = '8 GB';  time = '30 min' }
            withLabel: 'process_high'   { cpus = 4; memory = '16 GB'; time = '1 h'    }
        }
    }

    // ── Subset-of-proteins test (override list with --target_gene) ───────────
    test_subset_of_protein {
        includeConfig 'conf/local_refs.config'
        params {
            project        = 'test_subset_of_protein'
            outdir         = 'results/test_subset_of_protein'
            gene_dir       = null
            target_gene    = 'TP53,RAF1,BRAF,KRAS,EGFR'  // override: --target_gene 'A,B,C'
            mapping_mode   = 'all_isoform_mapping'
            blast_coverage = 90
            idmap_coverage = 80
            seq_cutoff     = 70
        }
        workDir          = '/dlab/home/norbi/PycharmProjects/discanvis_gencode_nextflow_subset'
        process.executor = 'local'
        process {
            withLabel: 'process_medium' { cpus = 6; memory = '16 GB'; time = '2 h' }
            withLabel: 'process_high'   { cpus = 8; memory = '32 GB'; time = '4 h' }
        }
    }

    // ── SLURM cluster (combine with conda or docker) ──────────────────────────
    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
    }

    // ── Cellular vulnerability — full proteome for Turbine ML model ─────────
    //   nextflow run main.nf -profile discanvis_data,cellular_vulnerability,conda -resume
    //   (cellular_vulnerability must come AFTER discanvis_data so its params take precedence)
    //   Gene-level filtering (798-gene panel) happens downstream in the feature builder.
    cellular_vulnerability {
        params {
            project               = 'cellular_vulnerability'
            outdir                = 'results/cellular_vulnerability'
            target_gene           = null          // full human proteome
            mapping_mode          = 'all_isoform_mapping'
            scatter_chunks        = 8
            blat_chunks           = 8
            per_gene_md_threshold = 50

            // tracks ON (most are on by default; explicitly enable a few)
            skip_pdb              = false
            skip_ppi              = false
            skip_cancer_drivers   = false
            skip_alphamissense    = false
            skip_depmap           = false

            // tracks OFF
            skip_polymorphism     = true
            skip_snp              = true
            skip_mavedb           = true
            skip_proteingym       = true
            skip_omim             = true
            skip_conservation     = true
            skip_pathogenicity    = true
            skip_coiledcoils      = true
            skip_scansite         = true
            skip_pem              = true
            skip_finches          = true
        }
    }

    // ── "Hit and run" full reproduction profile ───────────────────────────────
    // ZERO machine-specific paths: every refreshing reference is downloaded via
    // FETCH_* (cached in ref_dir), curated non-refreshing data comes from the
    // in-repo legacy_data/ (or Zenodo once params.zenodo_url is set), and PDB
    // uses the SIFTS bulk join. Licence-gated tracks (dbNSFP/OMIM/DepMap/TCGA/
    // cBioPortal) and the heavy GOPHER/phastCons recompute are left off for the
    // first clean run — enable them by supplying their params / a Zenodo archive.
    //   nextflow run main.nf -profile discanvis_data,conda
    //   (default 10 proteins; override with --target_gene 'A,B,...' or null=full)
    discanvis_data {
        params {
            mapping_mode   = 'all_isoform_mapping'
            target_gene    = 'TP53,RAF1,BRAF,KRAS,EGFR,PTEN,PIK3CA,AKT1,MYC,CTNNB1'
            gene_dir       = null
            outdir         = 'results/discanvis_data'

            // refreshing references → auto-download (null triggers FETCH_*)
            uniprot_fasta         = null
            uniprot_isoform_fasta = null
            gencode_fasta         = null
            gencode_gtf           = null
            gencode_transcripts   = null
            gencode_refseq        = null
            alphamissense_gz      = null
            clinvar_vcf           = null
            mondo_obo             = null
            ppi_intact = null; ppi_biogrid = null; ppi_hippie = null

            // genome + dbSNP + PDB → fetch / bulk
            hg38_2bit       = null;  fetch_hg38_2bit = true
            dbsnp_bb        = null;  fetch_dbsnp     = true
            pdb_bulk        = true;  sifts_tsv       = null

            // MaveDB + ProteinGym → fetched fresh and mapped with isoform fan-out
            mavedb_tsv = null;     fetch_mavedb     = true
            proteingym_tsv = null; fetch_proteingym = true
            skip_mavedb        = false
            skip_proteingym    = false

            // OMIM disease variants ← UniProt humsavar.txt (OPEN, no key)
            omim_tsv = null; omim_mutations_tsv = null
            fetch_omim = true; skip_omim = false

            // DepMap (open data) → fetched + mapped
            depmap_tsv = null; fetch_depmap = true; skip_depmap = false

            // Key/licence tracks: off until the user supplies a URL/key
            //   dbNSFP → set --dbnsfp_url; cBioPortal → --cbioportal_study; TCGA → --tcga_maf
            dbnsfp_tsv = null
            tcga_maf = null; cbioportal_maf = null
            gopher_conservation_table = null; phastcons_dir = null
            skip_conservation  = true
            skip_pathogenicity = true

            // disorder predictors: auto-setup on first run (SETUP_DEPS process).
            // Clones AIUPred, creates conda envs, installs bigBedToBed.
            // Cached in ext_programs/.nf_setup_done — skipped on every subsequent run.
            ext_programs = "${projectDir}/External_Programs"
            auto_setup   = true
        }
        workDir = 'work_discanvis_data'
    }
}

// ---------------------------------------------------------------------------
// Execution + reporting
// ---------------------------------------------------------------------------
executor {
    name   = 'local'
    cpus   = 120    // dlab server: 128 logical CPUs; reserve 8 for OS
    memory = '1400 GB'
}

timeline { enabled = true; overwrite = true; file = "${params.outdir}/reports/timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/reports/report.html"   }
dag      { enabled = true; overwrite = true; file = "${params.outdir}/reports/dag.html"      }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/reports/trace.tsv"; fields = 'task_id,name,status,exit,submit,start,complete,duration,realtime,cpus,peak_rss,peak_vmem,rchar,wchar' }

workflow.onComplete = {
    def status = workflow.success ? 'SUCCESS' : 'FAILED'
    def genes  = params.target_gene ? params.target_gene.toString().take(80) : 'all'
    println """
================================================
 DisCanVis Pipeline  ${status}
  Run ID   : ${workflow.runName}
  Duration : ${workflow.duration}
  Start    : ${workflow.start}
  Outdir   : ${params.outdir}
  Gene(s)  : ${genes}
  Reports  : ${params.outdir}/reports/
================================================
""".stripIndent()
}

workflow.onError = {
    println "Pipeline FAILED: ${workflow.errorMessage}"
}
